const io := import("../io")

ext fn printf(fmt: *u8, ...) -> i32

pub type TokenKind = enum(u8) {
    LitInteger
    LitFloat
    LitString

    Identifier
}

pub fn token_kind_name(kind: TokenKind) -> *u8 {
    return match kind {
        .LitInteger: "LIT_INT",
        .LitFloat:   "LIT_FLOAT",
        .LitString:  "LIT_STRING",
        
        .Identifier: "IDENT"
    }
}

pub fn main() -> error {
    const f := try io.open("Justfile", "r")
    defer f.close()

    mut buf: [256]u8
    const bytes_read := f.read(buf, 256)

    const file_len, file_data := try io.load_file("Justfile")
    defer io.free(file_data)

    printf("Read %u bytes from Justfile\n", file_len)
    printf("%.*s\n", file_len, cast(file_data, *u8))

    return 0
}
