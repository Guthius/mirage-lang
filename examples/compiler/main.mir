const std := import("std")
const io := import("io")

ext fn free(ptr: anyptr)

pub fn main() -> error {
    const f_len, f_bytes := try io.load_file("Justfile")
    defer free(f_bytes)

    io.printf("%.*s\n", f_len, f_bytes)

    mut hash_map: std.Dictionary

    const x: u32 = 5

    hash_map.init(sizeof(x))
    hash_map.put("key_a", &x)

    return 0
}
